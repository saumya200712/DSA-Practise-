class Solution {
public:

    bool checkChildrenSum(TreeNode* root) {

        // Empty tree
        if(root == NULL)
            return true;

        // Leaf node
        if(root->left == NULL && root->right == NULL)
            return true;

        int leftValue = 0;
        int rightValue = 0;

        if(root->left)
            leftValue = root->left->data;

        if(root->right)
            rightValue = root->right->data;

        bool currentNodeValid = (root->data == leftValue + rightValue);

        return currentNodeValid
            && checkChildrenSum(root->left)
            && checkChildrenSum(root->right);
    }
};
