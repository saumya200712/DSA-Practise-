first node encountered at every depth while traversing Right → Left

DRY RUN-

       1
     /   \
    2     3
     \     \
      5     4

DFS order (right first):

1
3
4
2
5

Levels seen first:

Level 0 → 1
Level 1 → 3
Level 2 → 4

Answer:
[1, 3, 4]


code- class Solution {
public:

    void dfs(TreeNode* root, int level, vector<int>& ans) {
      if(root ==NULL)
      return;

      if(level == ans.size()){
        ans.push_back(root->data);

        dfs(root->right,level+1;ans);
        dfs(root->left; level +1 ; ans);
      }



     vector<int> rightSideView(TreeNode* root) {
         vector<int> ans;
        dfs(root, 0, ans);
        return ans;
    }
};


Why level == ans.size()?
This make sure only right view elements get in the ans.
