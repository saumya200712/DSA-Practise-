class Solution {
public:
bool mirror(TreeNode* p, TreeNode* q){

    if(p == NULL && q == NULL)
        return true;

    if(p == NULL || q == NULL)
        return false;

    if(p->data != q->data)
        return false;

    return mirror(p->left, q->right) &&
           mirror(p->right, q->left);
}
    bool isSymmetric(TreeNode* root) {

       return mirror(root->left, root->right);

    }
};
