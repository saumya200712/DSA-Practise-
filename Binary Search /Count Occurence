class Solution {
public:

    int lowerBound(vector<int>& arr, int target) {

        int low = 0;
        int high = arr.size() - 1;
        int answer = arr.size();

        while(low <= high) {

            int mid = low + (high - low) / 2;

            if(arr[mid] >= target) {
                answer = mid;
                high = mid - 1;
            }
            else {
                low = mid + 1;
            }
        }

        return answer;
    }

    int upperBound(vector<int>& arr, int target) {

        int low = 0;
        int high = arr.size() - 1;
        int answer = arr.size();

        while(low <= high) {

            int mid = low + (high - low) / 2;

            if(arr[mid] > target) {
                answer = mid;
                high = mid - 1;
            }
            else {
                low = mid + 1;
            }
        }

        return answer;
    }

    int countOccurrences(vector<int>& arr, int target) {

        int lower = lowerBound(arr, target);
        int upper = upperBound(arr, target);

        return upper - lower;
    }
};
