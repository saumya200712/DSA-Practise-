Problem
You are given:

N stalls at positions arr[]
C cows
Place the cows in the stalls such that the minimum distance between any two cows is maximized.

This monotonic property allows binary search.

Sort stall positions.
Binary search on distance:
low = 1
high = arr[n-1] - arr[0]
For a distance mid, check if all cows can be placed.
If possible:
store answer
try larger distance (low = mid + 1)
Else:
reduce distance (high = mid - 1)


#include <bits/stdc++.h>
using namespace std;

bool canPlace(vector<int>& stalls, int cows, int dist) {
    int count = 1;
    int last = stalls[0];

    for (int i = 1; i < stalls.size(); i++) {
        if (stalls[i] - last >= dist) {
            count++;
            last = stalls[i];

            if (count >= cows)
                return true;
        }
    }

    return false;
}

int aggressiveCows(vector<int>& stalls, int cows) {
    sort(stalls.begin(), stalls.end());

    int low = 1;
    int high = stalls.back() - stalls.front();
    int ans = 0;

    while (low <= high) {
        int mid = low + (high - low) / 2;

        if (canPlace(stalls, cows, mid)) {
            ans = mid;
            low = mid + 1;   // try larger distance
        } else {
            high = mid - 1;  // reduce distance
        }
    }

    return ans;
}

