class Solution {
public:
  int NthRoot(int N, int M) {
    int X = 0  ;
    int low = 0;
    int high = M;

    while(low<=high){
        int mid = (low+high)/2;
        
        if(X<=mid){
            mid=X;
            low = mid+1;

        }
        else{
        high = mid-1;

    }
    }
    return X;
       
    }
};
