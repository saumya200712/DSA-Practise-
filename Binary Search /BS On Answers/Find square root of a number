class Solution {
public:
    int floorSqrt(int n)  {
        int low = 0;
        int high = n;
        int result = 0;

        while(low<=high){
           long long mid = (low+high)/2;

           if(mid*mid <=n){
           result = mid;
           low = mid+1;
        }
        else{
            high = mid-1;
        }
    }
    return result;
    }
};
