## The upper bound of x is defined as the smallest index i such that nums[i] > x.

class Solution{
public:
    int upperBound(vector<int> &nums, int x){
        int n = nums.size();
        int low = 0;
        int high = n-1;
        int ans = n;
        
        while(low<=high){
            int mid = (low + high) /2;
            
            if (nums[mid] > x){
            ans = mid;
            high = mid -1;
            }
            else {
                low = mid + 1;
            }
        }
        return ans;
    }
};
