Step 1: What is Prefix XOR?
Just like prefix sum stores sum till an index, prefix XOR stores XOR till an index.

For:
[4,2,2,6]
Index	Prefix XOR
0	4
1	4^2 = 6
2	6^2 = 4
3	4^6 = 2

So:
prefix = [4,6,4,2]

Subarray XOR = prefix[right] ^ prefix[left-1]

class Solution {
public:
    int subarraysWithXorK(vector<int>& nums, int k) {

        unordered_map<int, int> frequencyMap;

        int prefixXor = 0;
        int count = 0;

        frequencyMap[0] = 1;

        for (int number : nums) {

            prefixXor ^= number;

            int requiredXor = prefixXor ^ k;

            count += frequencyMap[requiredXor];

            frequencyMap[prefixXor]++;
        }

        return count;
    }
};
