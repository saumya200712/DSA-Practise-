Dry Run
arr = [1,2,3,4,5]
k = 2

Reverse first 2:

2 1 3 4 5

Reverse remaining:

2 1 5 4 3

Reverse whole array:

3 4 5 1 2

Correct answer.


class Solution {
public:
    void rotateArray(vector<int>& nums, int k) {
      int n = nums.size();
      k = k%n;

      reverse(nums.begin(), nums.begin()+k);  //reverse first k elements
      reverse(nums.begin()+k, nums.end());   // reverse the rest of elements aprat from k
      reverse(nums.begin(), nums.end());    //revere the hwole array 

    }
};
