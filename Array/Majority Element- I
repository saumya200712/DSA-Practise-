class Solution {

public:

   int majorityElement(vector<int>& numbers) {

    int candidate = 0;
    int count = 0;

    for(int value : numbers) {

        if(count == 0) {
            candidate = value;
        }

        if(value == candidate) {
            count++;
        }
        else {
            count--;
        }
    }

    return candidate;
}


