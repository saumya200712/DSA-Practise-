class Solution {
public:
    string reverseWords(string s) {

        reverse(s.begin(), s.end());

        int start = 0;
        int n = s.size();

        for(int end = 0; end <= n; end++)
        {
            if(end == n || s[end] == ' ')
            {
                reverse(s.begin() + start,s.begin() + end);

                start = end + 1;
            }
        }

        return s;
    }
};

Dry Run

Input:

"welcome to the jungle"

After reversing whole string:

"elgnuj eht ot emoclew"

Now reverse each word:

elgnuj -> jungle
eht    -> the
ot     -> to
emoclew -> welcome

Result:

"jungle the to welcome"
