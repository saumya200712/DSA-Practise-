class Solution {
public:
    string buildString(string text) {

        string result = "";

        for(char currentCharacter : text) {

            if(currentCharacter == '#') {

                if(!result.empty())
                    result.pop_back();
            }
            else {
                result.push_back(currentCharacter);
            }
        }

        return result;
    }

    bool backspaceCompare(string s, string t) {

        return buildString(s) == buildString(t);
    }
};
