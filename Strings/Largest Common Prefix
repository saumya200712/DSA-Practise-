class Solution {
public:
    string longestCommonPrefix(vector<string>& strs) {

   string ans = "";
for(int i =0; i<strs.size(); i++){

char currentCharacter = strs[0][i];   //take first string word as reference 

for(int j = 1; j<strs.size(); j++)  //helps to compare the other string character to the first one 

if(currentCharacter != strs[j][i]){
return ans;

}
ans.push_back(currentCharacter);
}
return ans;
}
};
