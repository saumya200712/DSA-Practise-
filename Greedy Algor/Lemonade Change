class Solution {
public:
    bool lemonadeChange(vector<int>& bills) {
int five = 0;
int ten =0;

for(int change: bills){

if(change == 5){
five++;
}

if(change == 10){
if(five>0){
five--;
ten++;
}
else{
return false;
}
}
//Got bill of 20
else{
if(ten>0 && five>0){
ten--;
five--;
}
else if(five>=3){
five-=3;
}
else{
return false;
   }
  }
}
return true;
}
};
