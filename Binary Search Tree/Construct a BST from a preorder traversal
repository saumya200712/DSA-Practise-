Brute force- O(N2) Cus array get scanned twice 
class Solution {
public:

    TreeNode* build(vector<int>& preorder, int start, int end) {

        if(start > end)
            return nullptr;

        TreeNode* root = new TreeNode(preorder[start]);

        int splitIndex = start + 1;

        while(splitIndex <= end &&
              preorder[splitIndex] < root->data) {
            splitIndex++;
        }

        root->left =
            build(preorder, start + 1, splitIndex - 1);

        root->right =
            build(preorder, splitIndex, end);

        return root;
    }

    TreeNode* bstFromPreorder(vector<int>& preorder) {

        return build(preorder, 0, preorder.size() - 1);
    }
};




