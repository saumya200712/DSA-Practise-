class BSTIterator {

    stack<TreeNode*> st;
    bool reverse;

public:

    BSTIterator(TreeNode* root, bool isReverse) {

        reverse = isReverse;
        pushAll(root);
    }

    void pushAll(TreeNode* node) {

        while(node) {

            st.push(node);

            if(reverse)
                node = node->right;
            else
                node = node->left;
        }
    }

    int next() {

        TreeNode* currentNode = st.top();
        st.pop();

        if(reverse)
            pushAll(currentNode->left);
        else
            pushAll(currentNode->right);

        return currentNode->data;
    }
};

class Solution {
public:

    bool twoSumBST(TreeNode* root, int k) {

        if(root == nullptr)
            return false;

        BSTIterator leftIterator(root, false);
        BSTIterator rightIterator(root, true);

        int leftValue = leftIterator.next();
        int rightValue = rightIterator.next();

        while(leftValue < rightValue) {

            int currentSum = leftValue + rightValue;

            if(currentSum == k)
                return true;

            else if(currentSum < k)
                leftValue = leftIterator.next();

            else
                rightValue = rightIterator.next();
        }

        return false;
    }
};
