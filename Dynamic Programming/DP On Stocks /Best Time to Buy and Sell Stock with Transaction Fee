Problem

Every time you sell, you have to pay a fee.
A transaction is completed only when you sell., thats why sucbtact the fee when buying 

class Solution {
public:
    int maxProfit(vector<int>& prices, int fee) {

        int n = prices.size();

        vector<int> ahead(2, 0);
        vector<int> curr(2, 0);

        for (int i = n - 1; i >= 0; i--) {

            // Can Buy
            curr[1] = max(
                -prices[i] + ahead[0],
                ahead[1]
            );

            // Holding
            curr[0] = max(
                prices[i] - fee + ahead[1],
                ahead[0]
            );

            ahead = curr;
        }

        return ahead[1];
    }
};
