State
dp[i][j]

= Minimum path sum from (i,j) to the bottom.

Movement

From (i,j) you can move to

      (i,j)
      /   \
 down     diagonal

(i+1,j)  (i+1,j+1)

instead of

up
left

Base Case

The last row already knows its answer.

dp[lastRow][j] = triangle[lastRow][j];

No movement possible.

class Solution {
public:
    int minimumTotal(vector<vector<int>>& triangle) {

        int n = triangle.size();

        vector<int> front = triangle[n-1];

        for(int i = n-2; i >= 0; i--)
        {
            vector<int> curr(n, 0);

            for(int j = 0; j <= i; j++)
            {
                int down = front[j];
                int diag = front[j+1];

                curr[j] = triangle[i][j] + min(down, diag);
            }

            front = curr;
        }

        return front[0];
    }
};
