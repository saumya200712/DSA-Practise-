Problem

You have stones:

0   1   2   3
10  20  30  10

The numbers are heights.

The frog starts at stone 0.

From any stone, it can jump:

1 step
or
2 steps

Cost of a jump:

abs(height[current] - height[next])

Goal:

Reach last stone with minimum energy.

class Solution {
public:

    int f(int ind, vector<int>& height, vector<int>& dp){

        if(ind == 0)
            return 0;

        if(dp[ind] != -1)
            return dp[ind];

        int left = f(ind - 1, height, dp) +
                   abs(height[ind] - height[ind - 1]);

        int right = INT_MAX;

        if(ind > 1){
            right = f(ind - 2, height, dp) +
                    abs(height[ind] - height[ind - 2]);
        }

        return dp[ind] = min(left, right);
    }

    int frogJump(int n, vector<int>& height){

        vector<int> dp(n, -1);

        return f(n - 1, height, dp);
    }
};
