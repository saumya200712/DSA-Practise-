class Solution {
public:
    vector<int> dijkstra(int V, vector<vector<int>> edges,int S) {
        vector<pair<int,int>> adj[V];

//Undirected graph needs adjancy list

        for(auto edge : edges) {
            int u = edge[0];
            int v = edge[1];
            int wt = edge[2];

            adj[u].push_back({v, wt});
            adj[v].push_back({u, wt});
        }

        vector<int> distance(V, 1e9); //infinity for all points

        distance[S] = 0;

        priority_queue<pair<int,int>, vector<pair<int,int>>, greater<pair<int,int>> > pq;

        pq.push({0, S});

        while(!pq.empty())
        {
            auto current = pq.top();

            pq.pop();

            int currentDistance = current.first;
            int node = current.second;

            for(auto neighbour : adj[node]) {

                int adjacentNode = neighbour.first;
                int edgeWeight = neighbour.second;

                if(currentDistance + edgeWeight < distance[adjacentNode])
                {
                    distance[adjacentNode] = currentDistance + edgeWeight;

                    pq.push(
                        {
                            distance[adjacentNode],
                            adjacentNode
                        }
                    );
                }
            }
        }

        return distance;
    }
};
