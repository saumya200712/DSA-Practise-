If you start BFS from every 1, it becomes very expensive.

Instead:

✅ Put all 0's into the queue initially
✅ Distance of every 0 = 0
✅ Run BFS simultaneously from all 0's

This is called Multi-Source BFS.

class Solution {
public:
    vector<vector<int>> updateMatrix(vector<vector<int>>& mat) {

        int n = mat.size();  //row
        int m = mat[0].size();   //col

        queue<pair<int,int>> q;

        vector<vector<int>> dist(n, vector<int>(m, -1));

        // Put all 0s in queue
        for(int i=0;i<n;i++){
            for(int j=0;j<m;j++){

                if(mat[i][j] == 0){
                    q.push({i,j});
                    dist[i][j] = 0;
                }
            }
        }

        int dr[] = {-1, 0, 1, 0};
        int dc[] = {0, 1, 0, -1};

        while(!q.empty()){

            auto [row,col] = q.front();
            q.pop();

            for(int k=0;k<4;k++){

                int nr = row + dr[k];
                int nc = col + dc[k];

                if(nr>=0 && nr<n && nc>=0 && nc<m && dist[nr][nc] == -1){

                    dist[nr][nc] = dist[row][col] + 1;  //keep expanding from 0 level to level 1 to level 2 

                    q.push({nr,nc});
                }
            }
        }

        return dist;
    }
};
