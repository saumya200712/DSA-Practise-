When a new land appears:

grid[r][c] = 1

it initially forms a new island.

So:  count++;

Then check 4 neighbours.

If neighbour is land and belongs to a different component:

union(current, neighbour);
count--;

## because two islands merged into one.

Node Numbering

Convert cell to DSU node:

node = row*m + col;

class DisjointSet {
public:
    vector<int> parent, size;

    DisjointSet(int n) {
        parent.resize(n);
        size.resize(n, 1);

        for(int i = 0; i < n; i++)
            parent[i] = i;
    }

    int findUPar(int node) {

        if(node == parent[node])
            return node;

        return parent[node] = findUPar(parent[node]);
    }

    void unionBySize(int u, int v) {

        int pu = findUPar(u);
        int pv = findUPar(v);

        if(pu == pv) return;

        if(size[pu] < size[pv]) {
            parent[pu] = pv;
            size[pv] += size[pu];
        }
        else {
            parent[pv] = pu;
            size[pu] += size[pv];
        }
    }
};

class Solution {
public:

    vector<int> numOfIslands(int n, int m,vector<vector<int>> &operators) {

        DisjointSet ds(n * m);

        vector<vector<int>> vis(n, vector<int>(m, 0));

        vector<int> ans;

        int cnt = 0;

        int dr[] = {-1, 0, 1, 0};
        int dc[] = {0, 1, 0, -1};

        for(auto it : operators) {

            int row = it[0];
            int col = it[1];

            // Already land
            if(vis[row][col]) {
                ans.push_back(cnt);
                continue;
            }

            // Convert water -> land
            vis[row][col] = 1;
            cnt++;

            int nodeNo = row * m + col;

            // Check all 4 neighbours
            for(int k = 0; k < 4; k++) {

                int nr = row + dr[k];
                int nc = col + dc[k];

                if(nr >= 0 && nr < n && nc >= 0 && nc < m &&vis[nr][nc]) { //within the boundary 

                    int adjNodeNo = nr * m + nc;

                    // Different islands
                    if(ds.findUPar(nodeNo)!= ds.findUPar(adjNodeNo)) {

                        cnt--;

                        ds.unionBySize(nodeNo, adjNodeNo); //otherwise same so forms a union and form one island together if same component
                    }
                }
            }

            ans.push_back(cnt);
        }

        return ans;
    }
};
