What is a Bipartite Graph?

A graph is bipartite if you can color all nodes using 2 colors such that:

No two adjacent nodes have same color.

A graph is bipartite iff it can be colored using 2 colors.

So maintain:

vector<int> color(n,-1);
-1 = not colored
0 = red
1 = blue

bool dfs(int node,int clr,vector<vector<int>>& graph,vector<int>& color){

    color[node] = clr; //mark the first node as coloured

    for(auto neigh : graph[node]){

        if(color[neigh] == -1){

            if(!dfs(neigh,1-clr,graph,color))
 
                return false;
        }

        else if(color[neigh] == clr)  //if the neighbour has same colour as node then not bipartite
        {
            return false;
        }
    }

    return true;
}

 bool isBipartite(vector<vector<int>>& graph)
    {
        int n = graph.size();

        vector<int> color(n,-1);

        for(int i=0;i<n;i++)
        {
            if(color[i] == -1)
            {
                if(!dfs(i,0,graph,color))
                    return false;
            }
        }

        return true;
    }
};
