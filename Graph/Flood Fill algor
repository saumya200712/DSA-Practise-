class Solution{

void dfs(vector<vector<int>>&image, int sr, int sc, int newColour, int row, int coloumn, int source){

    if(sr<0 || sr>=row || sc<0 || sc>=coloumn) //edge case jab out of bound hoojayei
             return;

      else if(image[sr][sc] != source)  //main condition for recursive call
              return;

 image[sr][sc] = newColour; //change the source to the new colour 

//perform dfs in 4 direction
dfs(image, sr-1, sc, newColour, row, coloumn, source );
dfs(image, sr+1, sc, newColour, row, coloumn, source );
dfs(image, sr, sc-1, newColour, row, coloumn, source );
dfs(image, sr, sc+1, newColour, row, coloumn, source );

}
    public:
    vector<vector<int>> floodFill(vector<vector<int>> &image,
                                  int sr, int sc, int newColour) {
      if(newColour == image[sr][sc])
        return image;
      int row = image.size();
      int coloumn = image[0].size();
      int source = image[sr][sc];

      dfs(image, sr, sc, newColour, row, coloumn, source );
      return image;
    }
};
