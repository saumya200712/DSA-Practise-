DAG-
Directed Graph
Weighted Edges
No Cycles
When we process a node, we are guaranteed that all paths leading into it have already been considered.So:

Topo Sort
    ↓
Relax edges
    ↓
Shortest Paths

ALGORITHM-
We build an adjancey list, and that too in pair to store the node value and the weight of teh edge
We then perfrom the toposort using DFS, and the relaxation is the main logic here *** dist[neghbour]+weight<dist[node] ***
Finally get the shortest path. 

CODE-
class Solution {
public:

    void topoSortDFS(int node,
                     vector<vector<pair<int,int>>>& adj,
                     vector<int>& visited,
                     stack<int>& topoStack)
    {
        visited[node] = 1;

        for(auto neighbourInfo : adj[node])
        {
            int neighbour = neighbourInfo.first;

            if(!visited[neighbour])
            {
                topoSortDFS(neighbour, adj, visited, topoStack);
            }
        }

        topoStack.push(node);
    }

    vector<int> shortestPath(int N, int M, vector<vector<int>>& edges)
    {
        vector<vector<pair<int,int>>> adj(N);

        for(auto edge : edges)
        {
            int u = edge[0];
            int v = edge[1];
            int weight = edge[2];

            adj[u].push_back({v, weight});
        }

        vector<int> visited(N, 0);
        stack<int> topoStack;

        for(int node = 0; node < N; node++)
        {
            if(!visited[node])
            {
                topoSortDFS(node, adj, visited, topoStack);
            }
        }

        vector<int> dist(N, 1e9);

        dist[0] = 0;

        while(!topoStack.empty())
        {
            int node = topoStack.top();
            topoStack.pop();

            if(dist[node] != 1e9)
            {
                for(auto neighbourInfo : adj[node])
                {
                    int neighbour = neighbourInfo.first;
                    int weight = neighbourInfo.second;

                    if(dist[node] + weight < dist[neighbour])
                    {
                        dist[neighbour] = dist[node] + weight;
                    }
                }
            }
        }

        for(int node = 0; node < N; node++)
        {
            if(dist[node] == 1e9)
            {
                dist[node] = -1;
            }
        }

        return dist;
    }
};
