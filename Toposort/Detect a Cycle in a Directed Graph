This problem is literally Topological Sort + one extra count variable.If Kahn's Algorithm processes fewer than V nodes, the remaining nodes must belong to a cycle.
class Solution {
public:
    bool isCyclic(int V, vector<int> adj[]) {

        vector<int> indegree(V, 0);

        // Calculate indegree
        for(int u = 0; u < V; u++) {
            for(int v : adj[u]) {
                indegree[v]++;
            }
        }

        queue<int> q;

        // Push indegree 0 nodes
        for(int i = 0; i < V; i++) {
            if(indegree[i] == 0) {
                q.push(i);
            }
        }

        int count = 0;

        while(!q.empty()) {

            int node = q.front();
            q.pop();

            count++;

            for(int neighbour : adj[node]) {

                indegree[neighbour]--;

                if(indegree[neighbour] == 0) {
                    q.push(neighbour);
                }
            }
        }

        return count != V;
    }
};
