HEAPIFY DOWN--- 
void heapifyDown(int index)
{
    int size = heap.size();

    while(true)
    {
        int leftChild = 2 * index + 1;
        int rightChild = 2 * index + 2;

        int smallest = index;

        if(leftChild < size &&
           heap[leftChild] < heap[smallest])
        {
            smallest = leftChild;
        }

        if(rightChild < size &&
           heap[rightChild] < heap[smallest])
        {
            smallest = rightChild;
        }

        if(smallest == index)
            break;

        swap(heap[index], heap[smallest]);

        index = smallest;
    }
}


