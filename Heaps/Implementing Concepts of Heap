Every Heapify Up code ever written does:


void heapifyUp(int index)
{
    while(index > 0)
    {
        int parentIndex = (index - 1) / 2;

        if(heap[parentIndex] <= heap[index])
            break;

        swap(heap[parentIndex], heap[index]);

        index = parentIndex;
    }
}

 SIMPLE WORDS--

while(not root)
{
    if(parent satisfies property)
        break;

    swap(parent, child);

    move upwards;
}

