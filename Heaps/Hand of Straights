class Solution {
public:
    bool isNStraightHand(vector<int>& hand, int groupSize) {

        int totalCards = hand.size();

        if(totalCards % groupSize != 0)
            return false;

        map<int,int> frequencyMap;

        for(int card : hand)
            frequencyMap[card]++;

        while(!frequencyMap.empty())
        {
            int startCard = frequencyMap.begin()->first;

            for(int currentCard = startCard;
                currentCard < startCard + groupSize;
                currentCard++)
            {
                if(frequencyMap.find(currentCard) == frequencyMap.end())
                    return false;

                frequencyMap[currentCard]--;

                if(frequencyMap[currentCard] == 0)
                    frequencyMap.erase(currentCard);
            }
        }

        return true;
    }
};
