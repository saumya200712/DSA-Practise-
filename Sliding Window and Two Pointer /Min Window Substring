class Solution {
public:
    string minWindow(string s, string t) {

        unordered_map<char, int> mp;

        // store frequency of t
        for(char ch : t) {
            mp[ch]++;
        }

        int left = 0;
        int count = 0;

        int minLen = INT_MAX;
        int startIndex = 0;

        for(int right = 0; right < s.length(); right++) {

            // current character
            char ch = s[right];

            // if character needed
            if(mp[ch] > 0) {
                count++;
            }

            // reduce frequency
            mp[ch]--;

            // all characters matched
            while(count == t.length()) {

                // update minimum answer
                if(right - left + 1 < minLen) {
                    minLen = right - left + 1;
                    startIndex = left;
                }

                // remove left character
                mp[s[left]]++;

                // important check
                if(mp[s[left]] > 0) {
                    count--;
                }

                left++;
            }
        }

        if(minLen == INT_MAX) {
            return "";
        }

        return s.substr(startIndex, minLen);
    }
};
