class Solution {
public:

    vector<int> maxSlidingWindow(vector<int>& arr, int k) {

        vector<int> ans;

        for(int i = 0; i <= arr.size() - k; i++) {

            int maxi = arr[i];

            for(int j = i; j < i + k; j++) {

                maxi = max(maxi, arr[j]);
            }

            ans.push_back(maxi);
        }

        return ans;
    }
};
