class Solution{
public:

    int xorTillN(int n)
    { //instead of looping 

        if(n % 4 == 0) return n;
        if(n % 4 == 1) return 1;
        if(n % 4 == 2) return n + 1;
        return 0;
    }

    int findRangeXOR(int l, int r) { //formula to get xor(L.......R), its cancels common term 

        return xorTillN(r) ^ xorTillN(l - 1);
    }
};
