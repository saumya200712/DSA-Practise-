OPTIMAAL METHOD--> 
Recursion first removes everything, then while coming back it rebuilds the stack in sorted order.

class Solution {
public:

    void insertSorted(stack<int>& st, int element) {

        if(st.empty() || element > st.top()) {
            st.push(element);
            return;
        }

        int topElement = st.top();
        st.pop();

        insertSorted(st, element);

        st.push(topElement);
    }

    void sortStack(stack<int>& st) {

        if(st.empty()) {
            return;
        }

        int topElement = st.top();
        st.pop();

        sortStack(st);

        insertSorted(st, topElement);
    }
};







