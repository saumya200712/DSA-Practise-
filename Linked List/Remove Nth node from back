Another method could be using prev and temp- 2 passes and we need to keep the length counted
class Solution {
public:
    ListNode* removeNthFromEnd(ListNode* head, int n) {

        int length = 0;
        ListNode* temp = head;

        while(temp) {
            length++;
            temp = temp->next;
        }

        int positionFromStart = length - n;

        // deleting head
        if(positionFromStart == 0) {
            ListNode* nodeToDelete = head;
            head = head->next;
            delete nodeToDelete;
            return head;
        }

        ListNode* prev = NULL;
        temp = head;

        while(positionFromStart--) {
            prev = temp;
            temp = temp->next;
        }

        prev->next = temp->next;
        delete temp;

        return head;
    }
};
