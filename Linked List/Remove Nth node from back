We're deleting the head.
Without a dummy node, handling this becomes a special case.

With:
dummy -> head

every deletion becomes: previousNode->next = previousNode->next->next;

No special cases needed. That's why almost every accepted solution uses a dummy nodeThat's the whole purpose of the dummy node: to create 
a fake node before the head so every node has a previous node.

We use 2 pointer method to optimize the soln

class Solution {
public:
    ListNode* removeNthFromEnd(ListNode* head, int n) {

        ListNode* dummy = new ListNode(0);
        dummy->next = head;

        ListNode* fast = dummy;
        ListNode* slow = dummy;

        // Move fast n+1 steps ahead
        for(int step = 0; step <= n; step++) {
            fast = fast->next;
        }

        // Maintain gap
        while(fast != NULL) {
            fast = fast->next;
            slow = slow->next;
        }

        ListNode* nodeToDelete = slow->next;
        slow->next = slow->next->next;
        delete nodeToDelete;

        return dummy->next;
    }
};

